{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "啟動 MotoAI 伺服器",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}/start-vscode.ps1"
      ],
      "options": {
        "cwd": "${workspaceFolder}",
        "env": {
          "PORT": "4173"
        }
      },
      "isBackground": true,
      "problemMatcher": {
        "owner": "motoai",
        "pattern": {
          "regexp": "^(.*)$",
          "message": 1
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "Smart Moto AI Platform running|MotoAI platform is already running",
          "endsPattern": "Smart Moto AI Platform running|MotoAI platform is already running"
        }
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      }
    }
  ]
}
